# INSPEC360 - Variáveis de Ambiente

# URL da API Backend - DESENVOLVIMENTO
# Use http://localhost:3000/api ou http://localhost:3001/api conforme sua porta
# Em PRODUÇÃO no Render, use: /api (rota relativa)
VITE_API_URL=http://localhost:3001/api

# Modo desenvolvimento
VITE_DEV_MODE=true

# Ambiente
VITE_ENV=development

# Nota: Para produção, copiar este arquivo para .env.production
# com VITE_API_URL=/api e VITE_DEV_MODE=false
