# INSPEC360 - Variáveis de Ambiente para Produção (Render)

# URL da API Backend - Usa rota relativa para funcionar com proxy
VITE_API_URL=/api

# Modo produção
VITE_DEV_MODE=false

# Ambiente
VITE_ENV=production

# Nota: Em produção no Render, todas as requisições /api são automaticamente
# roteadas para o backend Express via proxy configurado no render.yaml
